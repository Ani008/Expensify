<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Expensify"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="#000000" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Your shared journeys"
            android:textColor="#666666" />

        <EditText
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/search_bg"
            android:hint="Search workspaces..."
            android:padding="12dp"
            android:drawableStart="@drawable/search"
            android:drawableTint="@color/black"
            android:drawablePadding="10dp"
            android:inputType="text"
            android:importantForAutofill="no" />

        <TextView
            android:id="@+id/tvOpenTemplates"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:layout_marginTop="8dp"
            android:text="Browse Templates >"
            android:textColor="#1A1A1A"
            android:textSize="14sp"
            android:textStyle="bold"
            android:paddingVertical="4dp"
            android:paddingStart="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="vertical">

            <include android:id="@+id/cardEurope" layout="@layout/item_expense_group" />

            <include android:id="@+id/cardFlatmates" layout="@layout/item_expense_group" />

            <include android:id="@+id/cardOffice" layout="@layout/item_expense_group" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/dashed_placeholder_bg"
            android:gravity="center"
            android:padding="32dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="Plan a new journey to track\nexpenses with friends"
                android:textColor="#999999" />
        </LinearLayout>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>