<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F6F6F6"
    android:padding="24dp">

    <!-- Header with Back Arrow -->
    <ImageView
        android:id="@+id/btnBack"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:src="@android:drawable/ic_menu_revert"
        android:rotation="180"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:tint="#1A1A1A"
        android:contentDescription="Back" />

    <TextView
        android:id="@+id/tvHeader"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Create Group"
        android:textColor="#1A1A1A"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginStart="16dp"
        app:layout_constraintTop_toTopOf="@id/btnBack"
        app:layout_constraintBottom_toBottomOf="@id/btnBack"
        app:layout_constraintStart_toEndOf="@id/btnBack" />

    <!-- Group Name Input -->
    <TextView
        android:id="@+id/lblGroupName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="GROUP NAME"
        android:textColor="#999999"
        android:textSize="12sp"
        android:layout_marginTop="40dp"
        app:layout_constraintTop_toBottomOf="@id/btnBack"
        app:layout_constraintStart_toStartOf="parent" />

    <EditText
        android:id="@+id/etGroupName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="e.g., Euro Trip 2024"
        android:background="@android:color/transparent"
        android:paddingVertical="12dp"
        android:textSize="18sp"
        android:inputType="textCapWords"
        android:importantForAutofill="no"
        app:layout_constraintTop_toBottomOf="@id/lblGroupName" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#EEEEEE"
        app:layout_constraintTop_toBottomOf="@id/etGroupName" />

    <!-- Add Members Section -->
    <TextView
        android:id="@+id/lblAddMembers"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ADD MEMBERS"
        android:textColor="#999999"
        android:textSize="12sp"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/etGroupName"
        app:layout_constraintStart_toStartOf="parent" />

    <LinearLayout
        android:id="@+id/searchBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        app:layout_constraintTop_toBottomOf="@id/lblAddMembers">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@android:drawable/ic_menu_search"
            app:tint="#CCCCCC"
            android:contentDescription="Search" />

        <EditText
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Search by name or phone"
            android:background="@android:color/transparent"
            android:padding="12dp"
            android:textSize="16sp"
            android:inputType="text"
            android:importantForAutofill="no" />
    </LinearLayout>

    <!-- Member List -->
    <LinearLayout
        android:id="@+id/memberList"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/searchBar">

        <RelativeLayout android:layout_width="match_parent" android:layout_height="50dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Alex Rivera" android:textSize="18sp" android:textColor="#1A1A1A" android:layout_centerVertical="true"/>
            <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@android:drawable/ic_menu_close_clear_cancel" android:layout_alignParentEnd="true" android:layout_centerVertical="true" app:tint="#1A1A1A" android:contentDescription="Remove"/>
        </RelativeLayout>

        <RelativeLayout android:layout_width="match_parent" android:layout_height="50dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Sarah Chen" android:textSize="18sp" android:textColor="#1A1A1A" android:layout_centerVertical="true"/>
            <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@android:drawable/ic_menu_close_clear_cancel" android:layout_alignParentEnd="true" android:layout_centerVertical="true" app:tint="#1A1A1A" android:contentDescription="Remove"/>
        </RelativeLayout>
    </LinearLayout>

    <!-- Create Group Button -->
    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnCreateGroup"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Create Group"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        android:background="@drawable/black_button_bg"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>