<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:padding="24dp">

    <!-- Header -->
    <ImageView
        android:id="@+id/btnBack"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@android:drawable/ic_menu_revert"
        android:rotation="180"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:tint="#1A1A1A" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/search_bg"
        android:paddingHorizontal="12dp"
        android:paddingVertical="6dp"
        android:text="Group: Japan Trip"
        android:textColor="#666666"
        android:textSize="12sp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="Settlement Summary"
        android:textColor="#1A1A1A"
        android:textSize="28sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/btnBack"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="3 pending payments to clear all debts."
        android:textColor="#999999"
        android:textSize="14sp"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Total Settlement Card -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardSettlement"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="#F8F8F8"
        app:layout_constraintTop_toBottomOf="@id/tvSubtitle">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="24dp">
            <TextView
                android:id="@+id/lblTotal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TOTAL SETTLEMENT"
                android:textColor="#999999"
                android:textSize="10sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/lblTotal"
                android:layout_marginTop="4dp"
                android:text="₹ 4,250.00"
                android:textColor="#1A1A1A"
                android:textSize="24sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:background="@drawable/black_button_bg"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"
                android:text="VERIFIED"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:textStyle="bold" />
        </RelativeLayout>
    </androidx.cardview.widget.CardView>

    <TextView
        android:id="@+id/lblPending"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:text="PENDING TRANSACTIONS"
        android:textColor="#CCCCCC"
        android:textSize="12sp"
        android:textStyle="bold"
        android:letterSpacing="0.1"
        app:layout_constraintTop_toBottomOf="@id/cardSettlement"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Transactions List -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@id/lblPending">

        <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:paddingVertical="16dp">
            <TextView android:id="@+id/name1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Ravi" android:textColor="#1A1A1A" android:textSize="18sp" android:textStyle="bold"/>
            <ImageView android:layout_width="16dp" android:layout_height="16dp" android:layout_toEndOf="@id/name1" android:layout_marginStart="12dp" android:layout_centerVertical="true" android:src="@drawable/arrow_right" app:tint="#CCCCCC" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_toEndOf="@id/name1" android:layout_marginStart="44dp" android:text="Anita" android:textColor="#1A1A1A" android:textSize="18sp" android:textStyle="bold"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="₹500" android:textColor="#1A1A1A" android:textSize="18sp" android:textStyle="bold"/>
        </RelativeLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F0F0F0" />

        <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:paddingVertical="16dp">
            <TextView android:id="@+id/name2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Siddharth" android:textColor="#1A1A1A" android:textSize="18sp" android:textStyle="bold"/>
            <ImageView android:layout_width="16dp" android:layout_height="16dp" android:layout_toEndOf="@id/name2" android:layout_marginStart="12dp" android:layout_centerVertical="true" android:src="@drawable/arrow_right" app:tint="#CCCCCC" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_toEndOf="@id/name2" android:layout_marginStart="44dp" android:text="Anita" android:textColor="#1A1A1A" android:textSize="18sp" android:textStyle="bold"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="₹2,800" android:textColor="#1A1A1A" android:textSize="18sp" android:textStyle="bold"/>
        </RelativeLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F0F0F0" />

        <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:paddingVertical="16dp">
            <TextView android:id="@+id/name3" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Me" android:textColor="#1A1A1A" android:textSize="18sp" android:textStyle="bold"/>
            <ImageView android:layout_width="16dp" android:layout_height="16dp" android:layout_toEndOf="@id/name3" android:layout_marginStart="12dp" android:layout_centerVertical="true" android:src="@drawable/arrow_right" app:tint="#CCCCCC" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_toEndOf="@id/name3" android:layout_marginStart="44dp" android:text="Ravi" android:textColor="#1A1A1A" android:textSize="18sp" android:textStyle="bold"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="₹950" android:textColor="#1A1A1A" android:textSize="18sp" android:textStyle="bold"/>
        </RelativeLayout>

        <!-- Info Box -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="@drawable/dashed_placeholder_bg"
            android:padding="16dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <ImageView android:layout_width="16dp" android:layout_height="16dp" android:src="@android:drawable/ic_dialog_info" app:tint="#999999" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="Calculated using minimal transactions algorithm.\nEveryone will be settled in 3 transfers."
                android:textColor="#999999"
                android:textSize="11sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Bottom Buttons -->
    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnPay"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/black_button_bg"
        android:text="Pay via UPI"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@id/btnShare" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnShare"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/search_bg"
        android:text="Share Summary"
        android:textAllCaps="false"
        android:textColor="#1A1A1A"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>